{
    "name": "tcgunel/omnipay-denizbank",
    "type": "library",
    "description": "Omnipay extension for Denizbank (Interbank VPos)",
    "keywords": [
        "denizbank",
        "interbank",
        "vpos",
        "omnipay",
        "payment",
        "gateway",
        "3d secure",
        "odeme"
    ],
    "homepage": "https://github.com/tcgunel/omnipay-denizbank",
    "license": "MIT",
    "authors": [
        {
            "name": "Tolga Can Günel",
            "email": "tlgcngnl@gmail.com"
        },
        {
            "name": "Omnipay Contributors",
            "homepage": "https://github.com/tcgunel/omnipay-denizbank/contributors"
        }
    ],
    "autoload": {
        "psr-4": {
            "Omnipay\\Denizbank\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Omnipay\\Denizbank\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.3",
        "league/omnipay": "^3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9",
        "omnipay/tests": "^4",
        "brianium/paratest": "*",
        "fzaninotto/faker": "*",
        "http-interop/http-factory-guzzle": "^1.2",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.0"
    },
    "scripts": {
        "test": "vendor/bin/paratest --processes 6",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": "vendor/bin/pint",
        "lint-check": "vendor/bin/pint --test"
    }
}
